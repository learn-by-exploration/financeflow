{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start Server",
      "program": "${workspaceFolder}/src/server.js",
      "env": { "NODE_ENV": "development" }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run All Tests",
      "program": "${workspaceFolder}/node_modules/.bin/c8",
      "args": ["node", "--test", "--test-force-exit", "tests/*.test.js"],
      "env": { "NODE_ENV": "test" }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run Current Test File",
      "program": "${file}",
      "args": ["--test"],
      "env": { "NODE_ENV": "test" }
    }
  ]
}
