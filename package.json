{
  "name": "personalfi",
  "version": "7.3.1",
  "description": "Self-hosted personal finance manager with collaborative budgeting, expense splitting, and financial health tracking",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js | npx pino-pretty",
    "backup": "bash scripts/backup.sh",
    "test": "c8 node --test --test-force-exit tests/*.test.js",
    "test:fast": "node --test --test-force-exit tests/*.test.js",
    "test:auth": "node --test tests/auth*.test.js",
    "test:security": "node --test tests/security*.test.js tests/csrf.test.js tests/session*.test.js tests/token*.test.js",
    "test:perf": "node --test tests/performance.test.js tests/stress.test.js",
    "test:frontend": "node --test tests/ux-phase*.test.js",
    "seed": "node src/db/seed.js",
    "lint": "eslint src/ tests/ public/",
    "lint:fix": "eslint src/ tests/ public/ --fix",
    "format": "prettier --write src/ tests/ public/js/ public/css/",
    "format:check": "prettier --check src/ tests/ public/js/ public/css/",
    "build:docker": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose stop",
    "docker:logs": "docker compose logs -f",
    "docker:status": "docker compose ps",
    "docker:restart": "docker compose restart",
    "docker:setup-autostart": "bash scripts/setup-autostart.sh",
    "validate": "npm run lint && npm run format:check && npm run test:fast && npm audit --audit-level=high"
  },
  "keywords": [
    "personal-finance",
    "budgeting",
    "expense-tracker",
    "expense-splitting",
    "self-hosted",
    "sqlite",
    "express"
  ],
  "author": "Learn by Exploration",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "otpauth": "^9.5.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
